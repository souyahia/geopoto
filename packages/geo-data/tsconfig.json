{
  "extends": "@geopoto/tsconfig/node.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "rootDir": ".",
    "outDir": "dist",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "generated/**/*.json"],
  "exclude": ["node_modules", "dist"]
}
