{
  "name": "geopoto",
  "private": true,
  "scripts": {
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix --fix-suggestions --fix-dangerously",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "check": "pnpm lint && pnpm format && pnpm typecheck"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260330.1",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.18.1",
    "turbo": "2.9.1",
    "typescript": "6.0.2"
  },
  "packageManager": "pnpm@10.26.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
