{
  "name": "@geopoto/mobile",
  "version": "1.0.4",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "APP_VARIANT=development expo start --clear",
    "start:local": "APP_VARIANT=development REACT_NATIVE_PACKAGER_HOSTNAME=localhost expo start --clear --localhost",
    "start:lan": "APP_VARIANT=development expo start --clear --lan",
    "ios": "APP_VARIANT=development expo run:ios",
    "android": "APP_VARIANT=development expo run:android",
    "prebuild:ios": "APP_VARIANT=development expo prebuild --clean --pnpm -p ios",
    "prebuild:android": "APP_VARIANT=development expo prebuild --clean --pnpm -p android",
    "build:ios": "APP_VARIANT=development expo prebuild --clean --pnpm -p ios && APP_VARIANT=development expo run:ios",
    "build:android": "APP_VARIANT=development expo prebuild --clean --pnpm -p android && APP_VARIANT=development expo run:android",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@geopoto/geo-data": "workspace:*",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@nandorojo/galeria": "3.0.2",
    "@react-navigation/native": "7.2.4",
    "@shopify/react-native-skia": "^2.6.2",
    "dayjs": "^1.11.20",
    "eas-cli": "^19.0.8",
    "expo": "55.0.23",
    "expo-asset": "~55.0.17",
    "expo-build-properties": "~55.0.14",
    "expo-constants": "~55.0.11",
    "expo-dev-client": "55.0.22",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.10",
    "expo-linking": "~55.0.11",
    "expo-localization": "~55.0.11",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.10",
    "expo-splash-screen": "~55.0.21",
    "expo-sqlite": "~55.0.16",
    "expo-status-bar": "55.0.5",
    "heroui-native": "^1.0.3",
    "i18next": "^26.0.3",
    "lucide-react-native": "^1.14.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.76.0",
    "react-i18next": "^17.0.2",
    "react-native": "~0.83.4",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-mmkv": "^4.3.0",
    "react-native-nitro-modules": "^0.35.3",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.5",
    "react-native-worklets": "^0.8.3",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "ts-pattern": "^5.9.0",
    "uniwind": "^1.6.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@geopoto/tsconfig": "workspace:*",
    "@types/react": "~19.2.14"
  }
}
