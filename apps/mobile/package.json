{
  "name": "@geopoto/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --clear",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild:ios": "expo prebuild --clean --pnpm -p ios",
    "prebuild:android": "expo prebuild --clean --pnpm -p android",
    "build:ios": "expo prebuild --clean --pnpm -p ios && expo run:ios",
    "build:android": "expo prebuild --clean --pnpm -p android && expo run:android",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.14",
    "expo": "55.0.11",
    "expo-constants": "~55.0.11",
    "expo-dev-client": "55.0.22",
    "expo-linking": "~55.0.11",
    "expo-localization": "~55.0.11",
    "expo-router": "~55.0.10",
    "expo-status-bar": "55.0.5",
    "heroui-native": "^1.0.3",
    "i18next": "^26.0.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^17.0.2",
    "react-native": "~0.83.4",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-mmkv": "^4.3.0",
    "react-native-nitro-modules": "^0.35.3",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.5",
    "react-native-worklets": "^0.5.2",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "uniwind": "^1.6.1"
  },
  "devDependencies": {
    "@geopoto/tsconfig": "workspace:*",
    "@types/react": "~19.2.14"
  }
}
